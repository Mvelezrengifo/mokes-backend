{
  "name": "mokes-clinic-electron",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder -w",
    "package:win": "electron-packager . MokesClinic --platform=win32 --arch=x64 --out=dist --overwrite"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.1"
  },
  "build": {
    "appId": "com.mokes.clinic.desktop",
    "productName": "Mokes Clinic",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "../frontend/dist/**"
    ],
    "extraResources": [
      {
        "from": "../src/backend",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis"],
      "artifactName": "Mokes-Clinic-${version}-Setup.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
